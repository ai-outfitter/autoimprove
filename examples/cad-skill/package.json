{
  "name": "autoimprove-cad-skill-example",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "pretrain": "npm --prefix ../.. run build",
    "train": "node src/train.mjs",
    "dry-run": "node src/train.mjs --dry-run",
    "setup:python": "uv venv --python 3.12 --clear .venv && uv pip install --python .venv -r requirements.txt",
    "pretest": "npm --prefix ../.. run build",
    "test": "node --test"
  },
  "dependencies": {
    "@jscad/modeling": "2.13.0",
    "@tscad/modeling": "0.5.0",
    "replicad": "0.23.1",
    "replicad-opencascadejs": "0.23.0",
    "scad-js": "0.6.9"
  }
}
